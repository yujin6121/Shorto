{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "skipLibCheck": true,
    "allowJs": true,
    "outDir": "dist",
    "types": ["node"],
    "lib": ["es2022", "dom"]
  },
  "include": ["src/**/*", "server.ts"],
  "exclude": ["node_modules"]
}
